# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, '14.0'
prepare_react_native_project!

# Disable Flipper by default to avoid build issues
flipper_config = FlipperConfiguration.disabled

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'SkydiveTrackerTemp' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # Disable Flipper to avoid build issues
    :flipper_configuration => flipper_config,
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'SkydiveTrackerTempTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )
    
    # Fix for React Native 0.73 compatibility
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        # Set minimum iOS deployment target (RN 0.73 requires 14.0 for React-RCTLinking)
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
        
        # Fix C++ compilation for all targets
        config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
        config.build_settings['CLANG_CXX_LIBRARY'] = 'libc++'
        
        # Fix for Boost compilation issues
        if target.name == 'boost'
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'BOOST_ALL_NO_LIB=1'
        end
        
        # Fix for RCT-Folly compilation issues (critical for React Native 0.73)
        if target.name == 'RCT-Folly' || target.name.include?('RCT-Folly')
          config.build_settings['HEADER_SEARCH_PATHS'] ||= []
          config.build_settings['HEADER_SEARCH_PATHS'] << '"$(PODS_ROOT)/boost"'
          config.build_settings['HEADER_SEARCH_PATHS'] << '"$(PODS_ROOT)/boost/boost"'
          config.build_settings['HEADER_SEARCH_PATHS'] << '"$(PODS_ROOT)/RCT-Folly"'
          
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] ||= ['$(OTHER_CFLAGS)']
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] << '-DFOLLY_NO_CONFIG'
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] << '-DFOLLY_MOBILE=1'
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] << '-DFOLLY_USE_LIBCPP=1'
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] << '-DFOLLY_CFG_NO_COROUTINES=1'
          
          # Fix Unicode.cpp compilation
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'FOLLY_NO_CONFIG=1'
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'FOLLY_MOBILE=1'
        end
        
        # Fix for Folly compilation issues
        if target.name == 'Folly' || target.name.include?('folly')
          config.build_settings['HEADER_SEARCH_PATHS'] ||= []
          config.build_settings['HEADER_SEARCH_PATHS'] << '"$(PODS_ROOT)/boost"'
          config.build_settings['HEADER_SEARCH_PATHS'] << '"$(PODS_ROOT)/boost/boost"'
          config.build_settings['HEADER_SEARCH_PATHS'] << '"$(PODS_ROOT)/RCT-Folly"'
        end
        
        # Fix for glog compilation
        if target.name == 'glog'
          # Already handled by C++17 standard above
        end
        
        # Fix for React-Core and related pods - ensure Boost headers are accessible
        if target.name.include?('React') || target.name.include?('RCT')
          config.build_settings['HEADER_SEARCH_PATHS'] ||= []
          config.build_settings['HEADER_SEARCH_PATHS'] << '"$(PODS_ROOT)/boost"'
          config.build_settings['HEADER_SEARCH_PATHS'] << '"$(PODS_ROOT)/boost/boost"'
          config.build_settings['HEADER_SEARCH_PATHS'] << '"$(PODS_ROOT)/RCT-Folly"'
          
          # Ensure proper include paths
          config.build_settings['USER_HEADER_SEARCH_PATHS'] ||= []
          config.build_settings['USER_HEADER_SEARCH_PATHS'] << '"$(PODS_ROOT)/boost"'
        end
      end
    end
  end
end
