# Backend Environment Configuration

# Database
DATABASE_URL=sqlite:///./skydive_tracker.db

# Logging
LOG_LEVEL=INFO

# CORS - Comma-separated list of allowed origins
# For development, use "*" to allow all origins
# For production, specify exact origins like "https://example.com,https://app.example.com"
ALLOWED_ORIGINS=*

# Server
HOST=0.0.0.0
PORT=8000
